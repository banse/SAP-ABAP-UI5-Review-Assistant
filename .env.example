# =============================================================================
# SAP ABAP/UI5 Review Assistant — Environment Variables
# =============================================================================

# PostgreSQL connection string (async driver).
# When absent or unreachable the app starts without persistence.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sap_review_assistant

# Uvicorn host/port (used by run scripts, not read by the app itself)
# HOST=0.0.0.0
# PORT=8000
